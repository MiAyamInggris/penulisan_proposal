# ────────────────────────────────────────────────────────────────────────────
# HOW TO USE ON VERCEL
#   1. Copy this file → fill in every value below
#   2. In Vercel dashboard: Settings → Environment Variables → Import .env
#   3. Paste the filled-in file content and save
# ────────────────────────────────────────────────────────────────────────────

# PostgreSQL — Neon (https://neon.tech) → Connection Details
# DATABASE_URL  = Pooled connection string  (enables pgbouncer, port 5432)
# DIRECT_URL    = Non-pooled / direct string (required by Prisma migrate)
DATABASE_URL=postgresql://USER:PASS@ep-XXXX-XXXX.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15
DIRECT_URL=postgresql://USER:PASS@ep-XXXX-XXXX.REGION.aws.neon.tech/DBNAME?sslmode=require&connect_timeout=15

# NextAuth.js
# NEXTAUTH_SECRET  — generate with: openssl rand -base64 32
# NEXTAUTH_URL     — exact URL Vercel assigns (copy from Vercel project overview)
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_32_BYTE_BASE64_STRING
NEXTAUTH_URL=https://YOUR-PROJECT.vercel.app

# Vercel Blob Storage — for PDF / file uploads
# Get token from: Vercel dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXX
