# PostgreSQL — Neon (https://neon.tech) → Connection Details
# DATABASE_URL  = Pooled connection string  (enables pgbouncer, port 5432)
# DIRECT_URL    = Non-pooled / direct string (required by Prisma migrate)
DATABASE_URL=postgresql://neondb_owner:npg_G1cuPovYs8Sy@ep-shy-thunder-aozd1ofq-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://neondb_owner:npg_G1cuPovYs8Sy@ep-shy-thunder-aozd1ofq.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# NextAuth.js
