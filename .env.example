# ────────────────────────────────────────────────────────────────────────────
# HOW TO USE ON VERCEL
#   1. Copy this file → fill in every value below with YOUR OWN credentials
#   2. In Vercel dashboard: Settings → Environment Variables → Import .env
#   3. Paste the filled-in file content and save
#
# WARNING: Never commit real credentials to git. This file must contain
# only placeholder values.
# ────────────────────────────────────────────────────────────────────────────

# PostgreSQL — Neon (https://neon.tech) → Connection Details
# DATABASE_URL  = Pooled connection string  (enables pgbouncer, port 5432)
# DIRECT_URL    = Non-pooled / direct string (required by Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require

# NextAuth.js v5
# AUTH_SECRET  — generate with: openssl rand -base64 32
# AUTH_URL     — exact URL Vercel assigns (copy from Vercel project overview)
#
# IMPORTANT: NextAuth v5 uses AUTH_SECRET and AUTH_URL (not NEXTAUTH_SECRET/NEXTAUTH_URL).
# If you have old NEXTAUTH_SECRET / NEXTAUTH_URL variables set in Vercel, add the
# AUTH_SECRET / AUTH_URL versions too — v5 reads the new names first.
AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32
AUTH_URL=https://your-project-name.vercel.app

# ── File Storage ─────────────────────────────────────────────────────────────
# Supabase Storage is used when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set.
# It takes priority over Vercel Blob. Set up:
#   1. Create a Supabase project at https://supabase.com
#   2. Storage → New bucket → name: "uploads" → Public bucket: ON
#   3. Settings → API → copy Project URL and service_role key below
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_BUCKET=uploads

# Vercel Blob Storage — fallback if Supabase vars are not set
# Get token from: Vercel dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXX
