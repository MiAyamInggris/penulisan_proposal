generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  DOSEN
  MAHASISWA
}

enum ProdiCode {
  RPL
  IF
  DS
  SI
}

enum ProposalStatus {
  ENROLLED
  PROPOSAL_UPLOADED
  ASSIGNED
  BIMBINGAN
  DE_READY
  DE_COMPLETED
  REVISION_UPLOADED
  SEMINAR_REGISTERED
  SEMINAR_COMPLETED
  COMPLETED
}

enum EprtStatus {
  PENDING
  VERIFIED
}

enum SeminarStatus {
  REGISTERED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  SEMINAR_REGISTRATION
  EPRT_VERIFIED
  DE_SCORED
  ASSIGNMENT_MADE
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  password           String
  role               Role
  identifier         String
  isActive             Boolean  @default(true)
  isKetua              Boolean  @default(false)
  isKaprodi            Boolean  @default(false)
  maxBimbinganQuota    Int      @default(5)
  kodeDosen            String?
  kelompokKeahlianId   String?
  createdAt            DateTime @default(now())
  updatedAt          DateTime @updatedAt

  classesAsDosenKelas    Class[]           @relation("DosenKelas")
  enrollments            ClassEnrollment[]
  supervisedAsFirst      Proposal[]        @relation("Supervisor1Assigned")
  supervisedAsSecond     Proposal[]        @relation("Supervisor2Assigned")
  requestedAsFirst       Proposal[]        @relation("Supervisor1Requested")
  requestedAsSecond      Proposal[]        @relation("Supervisor2Requested")
  assignedDeskEvals      Proposal[]        @relation("DeskEvaluator")
  nilaiBimbingan         NilaiBimbingan[]
  deskEvaluationScores   DeskEvaluation[]
  nilaiLiteratureReview  NilaiLiteratureReview[]
  nilaiPresentasi        NilaiPresentasi[]
  eprtVerifications      EprtRecord[]      @relation("EprtVerifier")
  notificationsReceived  Notification[]    @relation("NotificationRecipient")

  kelompokKeahlian KelompokKeahlian? @relation("KKAnggota", fields: [kelompokKeahlianId], references: [id])
  ketuaDiKK        KelompokKeahlian? @relation("KKKetua")
  kaprodiDiProdi   Program?          @relation("KaprodiProgram")
  auditLogs        AuditLog[]        @relation("AuditLogUser")
}

model Program {
  id                  String    @id @default(cuid())
  name                String
  code                ProdiCode @unique
  literatureReviewPct Float
  bimbinganPct        Float
  deskEvaluationPct   Float
  presentasiPct       Float
  kaprodiId           String?   @unique

  classes Class[]
  kaprodi User?  @relation("KaprodiProgram", fields: [kaprodiId], references: [id])
}

model Class {
  id           String    @id @default(cuid())
  code         String
  name         String
  semester     String
  academicYear String
  programId    String
  dosenKelasId String
  deDeadline   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  program     Program           @relation(fields: [programId], references: [id])
  dosenKelas  User              @relation("DosenKelas", fields: [dosenKelasId], references: [id])
  enrollments ClassEnrollment[]
}

model ClassEnrollment {
  id         String   @id @default(cuid())
  classId    String
  studentId  String
  enrolledAt DateTime @default(now())
  isActive   Boolean  @default(true)

  class    Class       @relation(fields: [classId], references: [id])
  student  User        @relation(fields: [studentId], references: [id])
  proposal Proposal?
  eprt     EprtRecord?

  @@unique([classId, studentId])
}

// ─── Proposal ────────────────────────────────────────────────────────────────

model Proposal {
  id           String         @id @default(cuid())
  enrollmentId String         @unique
  titleId      String
  titleEn      String?
  topicArea    String?
  abstract     String?
  status       ProposalStatus @default(ENROLLED)

  proposalUrl        String?
  proposalUploadedAt DateTime?
  revisionUrl        String?
  presentationUrl    String?
  revisionUploadedAt DateTime?

  supervisor1RequestedId String?
  supervisor2RequestedId String?
  supervisor1AssignedId  String?
  supervisor2AssignedId  String?
  deskEvaluatorId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollment           ClassEnrollment        @relation(fields: [enrollmentId], references: [id])
  supervisor1Requested User?                  @relation("Supervisor1Requested", fields: [supervisor1RequestedId], references: [id])
  supervisor2Requested User?                  @relation("Supervisor2Requested", fields: [supervisor2RequestedId], references: [id])
  supervisor1Assigned  User?                  @relation("Supervisor1Assigned", fields: [supervisor1AssignedId], references: [id])
  supervisor2Assigned  User?                  @relation("Supervisor2Assigned", fields: [supervisor2AssignedId], references: [id])
  deskEvaluator        User?                  @relation("DeskEvaluator", fields: [deskEvaluatorId], references: [id])

  isHistoricalImport    Boolean  @default(false)

  bimbinganSessions     BimbinganSession[]
  nilaiBimbingan        NilaiBimbingan[]
  deskEvaluation        DeskEvaluation?
  nilaiLiteratureReview NilaiLiteratureReview[]
  seminar               Seminar?
  finalGrade            FinalGrade?
}

// ─── Bimbingan ───────────────────────────────────────────────────────────────

model BimbinganSession {
  id              String   @id @default(cuid())
  proposalId      String
  sessionNumber   Int
  date            DateTime
  topicsDiscussed String
  nextPlan        String
  notes           String?
  createdAt       DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])
}

model EprtRecord {
  id            String     @id @default(cuid())
  enrollmentId  String     @unique
  eprtDate      DateTime
  screenshotUrl String
  status        EprtStatus @default(PENDING)
  verifiedById  String?
  verifiedAt    DateTime?
  createdAt     DateTime   @default(now())

  enrollment ClassEnrollment @relation(fields: [enrollmentId], references: [id])
  verifiedBy User?           @relation("EprtVerifier", fields: [verifiedById], references: [id])
}

// ─── Scoring Forms ────────────────────────────────────────────────────────────

model NilaiBimbingan {
  id                  String   @id @default(cuid())
  proposalId          String
  pembimbingId        String
  pemilihanTema       Float
  researchQuestion    Float
  studiLiteratur1     Float
  studiLiteratur2     Float
  rencanaImplementasi Float
  kemandirian         Float
  prosesBimbingan     Float
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  proposal   Proposal @relation(fields: [proposalId], references: [id])
  pembimbing User     @relation(fields: [pembimbingId], references: [id])

  @@unique([proposalId, pembimbingId])
}

model DeskEvaluation {
  id               String   @id @default(cuid())
  proposalId       String   @unique
  evaluatorId      String
  isLate           Boolean  @default(false)
  latarBelakang    Float
  formulasiMasalah Float
  teoriPendukung   Float
  ideMetode        Float
  catatanReviewer  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  proposal  Proposal @relation(fields: [proposalId], references: [id])
  evaluator User     @relation(fields: [evaluatorId], references: [id])
}

model NilaiLiteratureReview {
  id                  String   @id @default(cuid())
  proposalId          String
  pembimbingId        String
  kualitasPustaka     Float
  kontenRumusan       Float
  analisisTujuan      Float
  kelengkapanKajian   Float
  kelebihanKekurangan Float
  relasiTeori         Float
  catatan             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  proposal   Proposal @relation(fields: [proposalId], references: [id])
  pembimbing User     @relation(fields: [pembimbingId], references: [id])

  @@unique([proposalId, pembimbingId])
}

// ─── Seminar ─────────────────────────────────────────────────────────────────

model Seminar {
  id            String        @id @default(cuid())
  proposalId    String        @unique
  registeredAt  DateTime      @default(now())
  scheduledDate DateTime?
  location      String?
  status        SeminarStatus @default(REGISTERED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  proposal        Proposal          @relation(fields: [proposalId], references: [id])
  nilaiPresentasi NilaiPresentasi[]
}

model NilaiPresentasi {
  id                  String   @id @default(cuid())
  seminarId           String
  pembimbingId        String
  latarBelakangScore  Float
  teoriPendukungScore Float
  toolsPemodelanScore Float
  pemaparanScore      Float
  komunikasiScore     Float
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  seminar    Seminar @relation(fields: [seminarId], references: [id])
  pembimbing User    @relation(fields: [pembimbingId], references: [id])

  @@unique([seminarId, pembimbingId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  recipientId String
  title       String
  message     String
  isRead      Boolean          @default(false)
  proposalId  String?
  createdAt   DateTime         @default(now())

  recipient User @relation("NotificationRecipient", fields: [recipientId], references: [id])
}

// ─── Kelompok Keahlian ───────────────────────────────────────────────────────

model KelompokKeahlian {
  id        String   @id @default(cuid())
  nama      String
  ketuaId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ketua User?  @relation("KKKetua", fields: [ketuaId], references: [id])
  dosen User[] @relation("KKAnggota")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  userRole   String
  action     String
  entityType String?
  entityId   String?
  detail     Json?
  createdAt  DateTime @default(now())

  user User @relation("AuditLogUser", fields: [userId], references: [id])
}

// ─── Settings ────────────────────────────────────────────────────────────────

model Setting {
  key   String @id
  value String
}

// ─── Final Grade ──────────────────────────────────────────────────────────────

model FinalGrade {
  id              String   @id @default(cuid())
  proposalId      String   @unique
  lrScore         Float?
  bimbinganScore  Float?
  deScore         Float?
  presentasiScore Float?
  weightedTotal   Float?
  gradeIndex      String?
  passed          Boolean?
  computedAt      DateTime?
  updatedAt       DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id])
}
